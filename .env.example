# =============================================================================
#  TEL GUDANG — Environment Variables
#  Copy file ini jadi .env dan isi nilainya untuk development lokal.
#  File .env TIDAK boleh di-commit ke git.
# =============================================================================

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telgudang

# --- Auth ---
# Minimal 32 karakter, gunakan string acak yang panjang
JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter-di-sini

# --- Server ---
# Port backend API
PORT=8082

# --- CORS (opsional) ---
# Daftar origin yang diizinkan di production, pisahkan dengan koma
# Contoh: https://telgudang.replit.app,https://custom-domain.com
# Kosongkan untuk development (semua origin diizinkan)
ALLOWED_ORIGINS=

# --- Logging (opsional) ---
# Level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
